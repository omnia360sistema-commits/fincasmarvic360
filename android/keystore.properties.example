# Copiar a keystore.properties (no versionar) y colocar el .jks junto a este archivo o ajustar la ruta.
# Generar keystore: keytool -genkey -v -keystore marvic-release.jks -keyalg RSA -keysize 2048 -validity 10000 -alias marvic
storeFile=marvic-release.jks
storePassword=cambiar
keyAlias=marvic
keyPassword=cambiar
